# ygfliege.be — Yangguofu Malatang Liège. Backend/auth/analytics instances for
# this restaurant are not provisioned yet (see plan follow-ups). Local dev runs
# a second tsb-service on :8081 against the `ygfliege` DB (seeded from
# tsb-service/seeds/ygfliege_menu.sql) and this app on :3001, so both brands
# can run side by side.
BASE_URL=http://localhost:3001
API_BASE_URL=http://localhost:8081/api/v1
S3_BUCKET_URL=
GRAPHQL_WS_URL=ws://localhost:8081/api/v1/graphql
UMAMI_HOST=https://analytics.nuagemagique.dev
UMAMI_WEBSITE_ID=

# Cloudflare Turnstile
NUXT_PUBLIC_TURNSTILE_SITE_KEY=

# Zitadel OIDC
ZITADEL_AUTHORITY=
ZITADEL_CLIENT_ID=
ZITADEL_NATIVE_CLIENT_ID=
